modules = ["ruby-3.2", "web", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "rm -f tmp/pids/server.pid && env -u DATABASE_URL bundle exec rails server -b 0.0.0.0 -p 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
PKMN_ENDPOINT = "https://pokeapi.co/api/v2/pokemon/"
TYPE_ENDPOINT = "https://pokeapi.co/api/v2/type/"
DEFAULT_PKMN = "jynx"
DEFAULT_PKMN_ID = "124"
DEFAULT_PKMN_TYPE = "ice"
DEFAULT_PKMN_URL = "https://pokeapi.co/api/v2/pokemon/jynx"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-lc", "env -u DATABASE_URL bundle exec rails db:prepare && env -u DATABASE_URL bundle exec rails server -e production -b 0.0.0.0 -p 5000"]
build = ["bash", "-lc", "bundle install --deployment --without development test"]
