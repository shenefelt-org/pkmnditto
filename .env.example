# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.

PKMN_ENDPOINT=https://pokeapi.co/api/v2/pokemon/
ITEM_ENDPOINT=https://pokeapi.co/api/v2/item/
TYPE_ENDPOINT=https://pokeapi.co/api/v2/type/
DEFAULT_PKMN=jynx
DEFAULT_PKMN_ID=124
DEFAULT_PKMN_URL=https://pokeapi.co/api/v2/pokemon/jynx
DEFAULT_ITEM=master-ball
DEFAULT_PKMN_TYPE=ice-psychic

# Generate with: rails secret
SECRET_KEY_BASE=replace_with_output_of_rails_secret
