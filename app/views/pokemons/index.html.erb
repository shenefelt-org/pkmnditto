<% content_for :title, "Pokemon" %>

<h1>Pokemon</h1>

<p><%= link_to "New pokemon", new_pokemon_path, class: "secondary" %></p>

<% if @pokemons.any? %>
  <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.75rem;">
    <% @pokemons.each do |pokemon| %>
      <article style="text-align:center; padding:0.75rem; margin:0;">
        <% if pokemon.image_url.present? %>
          <%= image_tag pokemon.image_url, alt: pokemon.name, style: "width:72px;height:72px;image-rendering:pixelated;" %>
        <% end %>
        <div><%= link_to pokemon.name.titleize, pokemon %></div>
        <% if pokemon.primary_type.present? %>
          <small><%= pokemon.primary_type %></small>
        <% end %>
      </article>
    <% end %>
  </div>
<% else %>
  <p>No pokemon yet. <%= link_to "Add one", new_pokemon_path %>.</p>
<% end %>
