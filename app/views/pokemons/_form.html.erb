<%= form_with(model: pokemon) do |form| %>
  <% if pokemon.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(pokemon.errors.count, "error") %> prohibited this pokemon from being saved:</h2>

      <ul>
        <% pokemon.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :poke_id, "Pokédex ID" %>
    <%= form.number_field :poke_id, min: 1 %>
  </div>

  <div>
    <%= form.label :pkmn_type, "Type" %>
    <%= form.text_field :pkmn_type, placeholder: "e.g. fire, water, grass" %>
  </div>

  <div>
    <%= form.label :base_exp, "Base experience" %>
    <%= form.number_field :base_exp, min: 0 %>
  </div>

  <div>
    <%= form.label :default_sprite, "Sprite URL" %>
    <%= form.url_field :default_sprite %>
  </div>

  <div>
    <%= form.label :abilities, "Abilities (one per line, or JSON array)" %>
    <%= form.text_area :abilities,
        value: (pokemon.abilities.is_a?(Array) ? pokemon.abilities.join("\n") : pokemon.abilities.to_s),
        rows: 4,
        placeholder: "overgrow\nchlorophyll" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
