<%= form_with(model: pokemon) do |form| %>
  <% if pokemon.errors.any? %>
    <article style="border:1px solid var(--pico-color-red-500);">
      <h4><%= pluralize(pokemon.errors.count, "error") %> prohibited this pokemon from being saved:</h4>
      <ul>
        <% pokemon.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </article>
  <% end %>

  <label>
    Name
    <%= form.text_field :name, required: true %>
  </label>

  <label>
    PokeAPI ID
    <%= form.number_field :pokeapi_id, required: true, min: 1 %>
  </label>

  <label>
    Primary type
    <%= form.text_field :primary_type %>
  </label>

  <label>
    Image URL
    <%= form.text_field :image_url %>
  </label>

  <div class="grid">
    <label>
      Height
      <%= form.number_field :height, min: 1 %>
    </label>
    <label>
      Weight
      <%= form.number_field :weight, min: 1 %>
    </label>
    <label>
      Base experience
      <%= form.number_field :base_experience, min: 0 %>
    </label>
  </div>

  <%= form.submit %>
<% end %>
