<%= form_with(model: item) do |form| %>
  <% if item.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

      <ul>
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :short_effect %>
    <%= form.text_field :short_effect %>
  </div>

  <div>
    <%= form.label :flavor_text %>
    <%= form.text_field :flavor_text %>
  </div>

  <div>
    <%= form.label :sprite, "Sprite URL" %>
    <%= form.url_field :sprite %>
  </div>

  <div>
    <%= form.label :url, "API URL" %>
    <%= form.url_field :url %>
  </div>

  <div>
    <%= form.label :generations, "Generations (JSON object)" %>
    <%= form.text_area :generations,
        value: (item.generations.is_a?(Hash) ? JSON.pretty_generate(item.generations) : item.generations.to_s),
        rows: 6,
        placeholder: '{"generation-i": ["red", "blue"]}' %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
