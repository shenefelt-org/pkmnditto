<p style="color: green"><%= notice %></p>

<% content_for :title, "Items" %>

<h1>Items</h1>

<%= form_with url: items_path, method: :get, local: true, class: "search-form" do |f| %>
  <div role="group">
    <%= f.search_field :q, value: @q, placeholder: "Search items by name, effect, or flavor text…", aria: { label: "Search items" } %>
    <%= f.submit "Search" %>
    <% if @q.present? %>
      <%= link_to "Clear", items_path, role: "button", class: "secondary" %>
    <% end %>
  </div>
<% end %>

<% if @q.present? %>
  <p><small><%= pluralize(@items.size, "result") %> for "<%= @q %>"</small></p>
<% end %>

<div id="items" class="items-grid">
  <% if @items.any? %>
    <% @items.each do |item| %>
      <%= link_to item, id: dom_id(item), class: "item-card" do %>
        <% if item.sprite.present? %>
          <%= image_tag item.sprite, alt: item.name, style: "max-width: 96px" %>
        <% end %>
        <div><%= item.name %></div>
      <% end %>
    <% end %>
  <% else %>
    <p><em>No items found.</em></p>
  <% end %>
</div>

<style>
  .items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }
  .item-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.75rem;
    border: 1px solid var(--pico-muted-border-color, #ccc);
    border-radius: 0.5rem;
    text-decoration: none;
  }
  .item-card:hover { background: var(--pico-card-sectioning-background-color, #f5f5f5); }
</style>

<%= link_to "New item", new_item_path %>

