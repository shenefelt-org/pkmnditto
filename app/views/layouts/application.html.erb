<!DOCTYPE html>
<html>

<head>
  <title>
    <%= content_for(:title) || "Pkmnditto" %>
  </title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Pkmnditto">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

      <%= yield :head %>

        <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
          <%#= tag.link rel: "manifest" , href: pwa_manifest_path(format: :json) %>

            <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
            <link rel="icon" href="/favicon.ico" type="image/x-icon">
            <link rel="apple-touch-icon" href="/icon.png">

            <%# Pico CSS — minimal classless CSS framework (https://picocss.com) %>
              <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

              <%# Includes all stylesheet files in app/assets/stylesheets %>
                <%= stylesheet_link_tag :app, "data-turbo-track"=> "reload" %>
</head>

<body>
  <main class="container">
    <nav>
      <ul>
        <li><strong>
            <%= link_to "Pkmnditto" , root_path %>
          </strong></li>
      </ul>
      <ul>
        <li>
          <%= link_to "Types" , types_path %>
        </li>
        <li>
          <%= link_to "Items" , items_path %>
        </li>
        <li>
          <%= link_to "Pokemon" , pokemons_path %>
        </li>
        <% if signed_in? %>
          <% if current_user.profile_image_url.present? %>
            <li>
              <%= image_tag current_user.profile_image_url, alt: current_user.display_name,
                style: "width:28px;height:28px;border-radius:50%;object-fit:cover;vertical-align:middle;" %>
            </li>
            <% end %>
              <li><small>Hi, <%= current_user.display_name %></small></li>
              <li>
                <%= link_to "Sign out" , signout_path, class: "secondary" %>
              </li>
              <% else %>
                <li>
                  <%= button_to "Sign in with Replit" , "/auth/replit" , method: :post, data: { turbo: false }, form: {
                    style: "display:inline" }, class: "contrast" %>
                </li>
                <% end %>
      </ul>
    </nav>

    <% flash.each do |type, msg| %>
      <article class="<%= type == 'alert' ? 'pico-color-red-500' : '' %>" style="padding:0.5rem 1rem;">
        <%= msg %>
      </article>
      <% end %>

        <%= yield %>
  </main>
</body>

</html>